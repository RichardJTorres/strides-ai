# Strava API credentials
# Create an app at https://www.strava.com/settings/api
STRAVA_CLIENT_ID=your_client_id
STRAVA_CLIENT_SECRET=your_client_secret

# ── HEVY (weightlifting) ──────────────────────────────────────────────────────
# Required for lifting mode. Requires a Hevy Pro subscription.
# Get your key at https://hevy.com/settings?developer
# HEVY_API_KEY=your_hevy_api_key

# ── LLM provider ─────────────────────────────────────────────────────────────
# Set PROVIDER to "claude" (default), "gemini", or "ollama"
PROVIDER=claude

# Claude (default provider)
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key
# Optional: override the model (default: claude-sonnet-4-6)
# CLAUDE_MODEL=claude-opus-4-6

# Gemini
# Get your key at https://aistudio.google.com/apikey
# PROVIDER=gemini
# GEMINI_API_KEY=your_gemini_api_key
# GEMINI_MODEL=gemini-2.5-flash   # optional, defaults to first model returned by the API

# OpenAI / ChatGPT
# Get your key at https://platform.openai.com/api-keys
# PROVIDER=openai
# OPENAI_API_KEY=your_openai_api_key
# OPENAI_MODEL=gpt-4o   # optional, defaults to first model returned by the API

# Ollama (local, no API key required)
# Requires Ollama running at the host below with the chosen model pulled.
# PROVIDER=ollama
# OLLAMA_MODEL=llama3.1
# OLLAMA_HOST=http://localhost:11434   # optional, this is the default
